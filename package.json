{
  "name": "queue-panel",
  "version": "1.2.0",
  "description": "Desktop tray application for theme park wait times powered by Queue-Times.com",
  "main": "desktop/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "mobile:prepare": "node scripts/prepare-android-web.js",
    "android:sync": "npm run mobile:prepare && cap sync android",
    "android:open": "npm run android:sync && cap open android"
  },
  "keywords": [
    "theme-parks",
    "wait-times",
    "queue-times",
    "electron",
    "desktop",
    "tray"
  ],
  "author": "Intentional-QRM",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.queuepanel.app",
    "productName": "Queue Panel",
    "win": {
      "target": "nsis",
      "icon": "assets/icon256.png"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1"
  }
}
